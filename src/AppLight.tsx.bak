                  weightStart={300}
                  weightEnd={500}
                  spacingStart={0.02}
                  spacingEnd={-0.02}
                  scaleStart={1}
                  scaleEnd={1.02}
                  breathe={true}
                  breatheDuration={3.5}
                >
