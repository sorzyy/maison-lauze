                style={{ fontFamily: F.ui }}>
                Voir toutes les cuvées <ChevronRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
              </a>
            </div>

            <div className="flex gap-5 overflow-x-auto pb-4" style={{ scrollSnapType: 'x mandatory', scrollbarWidth: 'none' }}>
              {featuredWines.map((wine, i) => {
                const age = new Date().getFullYear() - wine.vintage;
                return (
                  <TiltCard key={i}
                    className="flex-shrink-0 w-64 rounded-2xl overflow-hidden group cursor-pointer"
                    style={{ scrollSnapAlign: 'start', background: '#fff', border: '1px solid rgba(92,26,42,0.1)', boxShadow: '0 8px 30px rgba(92,26,42,0.08)' }}
                    onClick={() => setSelectedWine(wine)}>
                    <div className="relative h-64 overflow-hidden" style={{ background: '#f8f4ef' }}>
                      <img src={wine.image} alt={wine.name}
                        className="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-700"
                        style={{ filter: 'drop-shadow(0 10px 25px rgba(92,26,42,0.4))' }} />
                      <div className="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />

                      <div
                        className="absolute inset-0 flex items-end p-4 z-20"
                        style={{
                          background: 'linear-gradient(to top, rgba(8,1,1,0.95) 60%, rgba(8,1,1,0.6))',
                          clipPath: 'inset(100% 0 0 0)',
                          transition: 'clip-path 0.5s cubic-bezier(0.76,0,0.24,1)',
                        }}
                        onMouseEnter={e => (e.currentTarget.style.clipPath = 'inset(0% 0 0 0)')}
                        onMouseLeave={e => (e.currentTarget.style.clipPath = 'inset(100% 0 0 0)')}
                      >
                        <p className="text-white/90 text-sm leading-[1.65]"
                          style={{ fontFamily: F.display, fontStyle: 'italic' }}>
                          "{wine.poem}"
                        </p>
                      </div>

                      {wine.badge && (
                        <span className="absolute top-3 left-3 text-xs px-3 py-1 rounded-full z-10"
                          style={{ fontFamily: F.ui, background: `rgba(92,26,42,0.85)`, color: '#fff' }}>
                          {wine.badge}
                        </span>
                      )}
                      <span className="absolute top-3 right-3 text-xs px-2 py-1 rounded-md bg-black/50 text-white/70 z-10"
                        style={{ fontFamily: F.ui }}>
                        {wine.type}
                      </span>
                    </div>

                    <div className="p-5">
                      <p className="text-xs mb-2 italic" style={{ fontFamily: F.display, color: 'rgba(139,58,26,0.7)' }}>
                        Millésime {wine.vintage} — {age} {age > 1 ? 'ans' : 'an'} de patience
                      </p>
                      <p className="text-xs tracking-[0.15em] uppercase mb-1" style={{ fontFamily: F.ui, color: C.light }}>{wine.appellation}</p>
                      <p className="text-lg font-light mb-0.5" style={{ fontFamily: F.display }}>{wine.name}</p>
                      <p className="text-sm mb-3" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.5)' }}>{wine.region}</p>
                      <p className="text-xs mb-4" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.3)' }}>{wine.grapes}</p>
                      <div className="flex items-center justify-between">
                        <span className="text-xl font-light" style={{ fontFamily: F.display, color: '#8b3a1a' }}>{wine.price}</span>
                        <a href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" target="_blank" rel="noopener"
                          className="p-2 rounded-full hover:scale-110 transition-transform"
                          style={{ background: `rgba(92,26,42,0.4)` }}>
                          <ShoppingBag className="w-4 h-4" />
                        </a>
                      </div>
                    </div>
                  </TiltCard>
                );
              })}
            </div>
          </div>
        </section>

