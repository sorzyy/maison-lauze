              <div className="space-y-3">
                <div className="reveal-up flex items-center gap-3">
                  <Star className="w-5 h-5" style={{ color: C.light }} />
                  <span className="text-xs tracking-[0.25em] uppercase" style={{ fontFamily: F.ui, color: C.light }}>Nos Cuvées</span>
                </div>
                <VariableText
                  as="h2"
                  className="reveal-up text-[clamp(2.5rem,5vw,4.5rem)]"
