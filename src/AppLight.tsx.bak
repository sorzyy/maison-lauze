// ── Quiz Modal ────────────────────────────────────────────────────────────────
function QuizModal({ onClose }: { onClose: () => void }) {
  const [step, setStep] = useState(0);
  const [scores, setScores] = useState([0, 0, 0, 0, 0]);
  const [done, setDone] = useState(false);

  const pick = (optScores: number[]) => {
    const next = scores.map((s, i) => s + optScores[i]);
    setScores(next);
    if (step < QUIZ_QUESTIONS.length - 1) setStep(step + 1);
    else setDone(true);
  };

  const recommended = [...featuredWines]
    .map((w, i) => ({ ...w, score: scores[i] }))
    .sort((a, b) => b.score - a.score)
    .slice(0, 3);

  return (
    <div className="fixed inset-0 z-[300] flex items-center justify-center p-4"
      style={{ background: 'rgba(0,0,0,0.88)', backdropFilter: 'blur(24px)' }}
      onClick={e => e.target === e.currentTarget && onClose()}>
      <div className="relative w-full max-w-lg rounded-3xl overflow-hidden"
        style={{ background: 'linear-gradient(160deg, #100505, #080202)', border: '1px solid rgba(92,26,42,0.45)', boxShadow: '0 40px 120px -20px rgba(92,26,42,0.5)' }}>
        <button className="absolute top-5 right-5 z-10 p-2 rounded-full text-white/40 hover:text-white hover:bg-white/10 transition-all" onClick={onClose}>
          <X className="w-4 h-4" />
        </button>

        {!done ? (
          <div className="p-8 md:p-10">
            <div className="flex gap-1.5 mb-8">
              {QUIZ_QUESTIONS.map((_, i) => (
                <div key={i} className="h-0.5 flex-1 rounded-full"
                  style={{ background: i <= step ? `linear-gradient(90deg, ${C.primary}, ${C.light})` : 'rgba(255,255,255,0.1)', transition: 'background 0.4s ease' }} />
              ))}
            </div>
            <p className="text-xs tracking-[0.25em] uppercase mb-1" style={{ fontFamily: F.ui, color: C.light }}>
              La Cave Cognard · {step + 1} / {QUIZ_QUESTIONS.length}
            </p>
            <p className="text-xs text-white/25 mb-6" style={{ fontFamily: F.ui }}>{QUIZ_QUESTIONS[step].sub}</p>
            <h3 className="text-3xl md:text-4xl font-light mb-8 leading-[1.1]" style={{ fontFamily: F.display }}>
              {QUIZ_QUESTIONS[step].question}
            </h3>
            <div className="grid grid-cols-2 gap-3">
              {QUIZ_QUESTIONS[step].options.map((opt, i) => (
                <button key={i} onClick={() => pick(opt.scores)}
                  className="p-4 rounded-2xl text-left transition-all duration-200 active:scale-95"
                  style={{ background: 'rgba(255,255,255,0.8)', border: '1px solid rgba(255,255,255,0.08)' }}
                  onMouseEnter={e => { (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(92,26,42,0.7)'; (e.currentTarget as HTMLButtonElement).style.background = 'rgba(92,26,42,0.15)'; }}
                  onMouseLeave={e => { (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(255,255,255,0.08)'; (e.currentTarget as HTMLButtonElement).style.background = 'rgba(255,255,255,0.8)'; }}>
                  <div className="text-2xl mb-2">{opt.icon}</div>
                  <p className="text-sm text-white/80 font-medium leading-snug" style={{ fontFamily: F.ui }}>{opt.label}</p>
                </button>
              ))}
            </div>
          </div>
        ) : (
          <div className="p-8 md:p-10">
            <div className="w-10 h-10 rounded-full flex items-center justify-center mb-5"
              style={{ background: 'rgba(92,26,42,0.3)', border: '1px solid rgba(92,26,42,0.6)' }}>
              <Star className="w-5 h-5" style={{ color: '#8b3a1a' }} />
            </div>
            <p className="text-xs tracking-[0.25em] uppercase mb-1" style={{ fontFamily: F.ui, color: C.light }}>Votre sélection personnalisée</p>
            <h3 className="text-3xl font-light mb-1" style={{ fontFamily: F.display }}>Votre cave idéale</h3>
            <p className="text-sm text-white/35 mb-7" style={{ fontFamily: F.ui }}>Estelle a choisi pour vous</p>
            <div className="space-y-3 mb-7">
              {recommended.map((wine, i) => (
                <a key={i} href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" target="_blank" rel="noopener"
                  className="flex items-center gap-4 p-4 rounded-2xl transition-all duration-300"
                  style={{ background: 'rgba(255,255,255,0.8)', border: '1px solid rgba(92,26,42,0.1)' }}
                  onMouseEnter={e => { (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(92,26,42,0.5)'; }}
                  onMouseLeave={e => { (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(92,26,42,0.1)'; }}>
                  <img src={wine.image} alt={wine.name} className="w-12 h-16 object-cover rounded-xl flex-shrink-0" />
                  <div className="flex-1 min-w-0">
                    <p className="text-xs mb-0.5" style={{ fontFamily: F.ui, color: C.light }}>{wine.appellation}</p>
                    <p className="font-light text-sm truncate" style={{ fontFamily: F.display }}>{wine.name}</p>
                    <p className="text-xs text-white/40" style={{ fontFamily: F.ui }}>{wine.cuvee}</p>
                  </div>
                  <div className="text-right flex-shrink-0">
                    <p className="text-xl font-light" style={{ fontFamily: F.display, color: '#8b3a1a' }}>{wine.price}</p>
                    {i === 0 && <p className="text-xs mt-0.5" style={{ color: C.light, fontFamily: F.ui }}>★ Coup de cœur</p>}
                  </div>
                </a>
              ))}
            </div>
            <div className="flex gap-3">
              <a href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" target="_blank" rel="noopener"
                className="flex-1 py-3 rounded-full text-sm tracking-[0.1em] uppercase text-center"
                style={{ fontFamily: F.ui, background: `linear-gradient(135deg, ${C.dark}, ${C.primary})` }}
                onClick={onClose}>
                Commander
              </a>
              <button onClick={() => { setStep(0); setScores([0,0,0,0,0]); setDone(false); }}
                className="px-5 py-3 rounded-full text-sm tracking-[0.1em] uppercase border border-white/20 hover:bg-white/5 transition-all"
                style={{ fontFamily: F.ui }}>
                Refaire
              </button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ── Wine Detail Panel ─────────────────────────────────────────────────────────
type Wine = typeof featuredWines[number];
function WineDetailPanel({ wine, onClose }: { wine: Wine; onClose: () => void }) {
  const ref = useRef<HTMLDivElement>(null);
  useEffect(() => {
    const el = ref.current;
    if (!el) return;
    requestAnimationFrame(() => { el.style.transform = 'translateX(0)'; el.style.opacity = '1'; });
    const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') onClose(); };
    document.addEventListener('keydown', onKey);
    return () => document.removeEventListener('keydown', onKey);
  }, [onClose]);

  const close = () => {
    const el = ref.current;
    if (el) { el.style.transform = 'translateX(60px)'; el.style.opacity = '0'; }
    setTimeout(onClose, 300);
  };

  return (
    <div className="fixed inset-0 z-[300] flex justify-end" onClick={close}>
      <div className="absolute inset-0" style={{ background: 'rgba(0,0,0,0.65)', backdropFilter: 'blur(4px)' }} />
      <div ref={ref} onClick={e => e.stopPropagation()}
        className="relative h-full w-full max-w-md flex flex-col overflow-y-auto"
        style={{
          background: 'linear-gradient(160deg, #120404 0%, #0a0202 100%)',
          borderLeft: '1px solid rgba(92,26,42,0.3)',
          transform: 'translateX(60px)', opacity: '0',
          transition: 'transform 0.4s cubic-bezier(0.23,1,0.32,1), opacity 0.4s ease',
          boxShadow: '-30px 0 80px -10px rgba(0,0,0,0.8)',
        }}>

        {/* Header image */}
        <div className="relative h-72 flex-shrink-0 overflow-hidden"
          style={{ background: '#0d0202' }}>
          <img src={wine.image} alt={wine.name}
            className="w-full h-full object-contain p-6"
            style={{ filter: 'drop-shadow(0 20px 40px rgba(92,26,42,0.5))' }} />
          <div className="absolute inset-0 bg-gradient-to-t from-[#0a0202] via-transparent to-transparent" />
          <button onClick={close}
            className="absolute top-4 right-4 w-9 h-9 rounded-full flex items-center justify-center text-white/50 hover:text-white hover:bg-white/10 transition-all"
            style={{ border: '1px solid rgba(255,255,255,0.1)' }}>
            <X className="w-4 h-4" />
          </button>
          {wine.badge && (
            <span className="absolute top-4 left-4 text-xs px-3 py-1 rounded-full"
              style={{ fontFamily: F.ui, background: 'rgba(92,26,42,0.9)', color: '#fff' }}>
              {wine.badge}
            </span>
          )}
        </div>

        {/* Content */}
        <div className="flex-1 p-7 space-y-6">
          <div>
            <p className="text-xs tracking-[0.2em] uppercase mb-1" style={{ fontFamily: F.ui, color: C.light }}>{wine.appellation}</p>
            <h2 className="text-3xl font-light mb-1" style={{ fontFamily: F.display }}>{wine.name}</h2>
            <p className="text-sm text-white/40 italic" style={{ fontFamily: F.display }}>{wine.cuvee}</p>
          </div>

          <p className="text-white/60 leading-[1.7] italic" style={{ fontFamily: F.display }}>"{wine.poem}"</p>

          {/* Stats row */}
          <div className="grid grid-cols-3 gap-3">
            {[
              { label: 'Millésime', value: wine.vintage.toString() },
              { label: 'Service', value: wine.temp || '—' },
              { label: 'Alcool', value: wine.alcool || '—' },
            ].map(({ label, value }) => (
              <div key={label} className="rounded-xl p-3 text-center"
                style={{ background: 'rgba(255,255,255,0.8)', border: '1px solid rgba(92,26,42,0.1)' }}>
                <p className="text-lg font-light" style={{ fontFamily: F.display, color: C.light }}>{value}</p>
                <p className="text-[10px] tracking-[0.15em] uppercase text-white/30 mt-0.5" style={{ fontFamily: F.ui }}>{label}</p>
              </div>
            ))}
          </div>

          {/* Tasting */}
          {wine.tasting && (
            <div className="space-y-2">
              <p className="text-xs tracking-[0.2em] uppercase text-white/30" style={{ fontFamily: F.ui }}>Dégustation</p>
              <p className="text-sm text-white/70 leading-[1.7]">{wine.tasting}</p>
            </div>
          )}

          {/* Pairing */}
          {wine.pairing && (
            <div className="space-y-2">
              <p className="text-xs tracking-[0.2em] uppercase text-white/30" style={{ fontFamily: F.ui }}>Accords mets & vins</p>
              <p className="text-sm text-white/70">{wine.pairing}</p>
            </div>
          )}

          {/* Garde */}
          {wine.garde && (
            <div className="rounded-xl p-4 flex items-center gap-4"
              style={{ background: 'rgba(92,26,42,0.12)', border: '1px solid rgba(92,26,42,0.25)' }}>
              <div>
                <p className="text-xs tracking-[0.15em] uppercase text-white/30 mb-0.5" style={{ fontFamily: F.ui }}>Potentiel de garde</p>
                <p className="text-xl font-light" style={{ fontFamily: F.display, color: C.light }}>{wine.garde}</p>
              </div>
            </div>
          )}

          {/* CTA */}
          <a href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" target="_blank" rel="noopener"
            className="flex items-center justify-center gap-2 w-full py-3.5 rounded-full text-sm tracking-[0.12em] uppercase text-white"
            style={{ fontFamily: F.ui, background: `linear-gradient(135deg, ${C.primary}, ${C.light})`, boxShadow: `0 8px 30px -6px rgba(92,26,42,0.6)` }}>
            <ShoppingBag className="w-4 h-4" /> Commander — {wine.price}
          </a>
        </div>
      </div>
    </div>
  );
}

// ── App ───────────────────────────────────────────────────────────────────────
export default function App() {
  const containerRef = useRef<HTMLDivElement>(null);
  const scrollStageRef = useRef<HTMLDivElement>(null);
  const [loaded, setLoaded] = useState(false);
  const [menuOpen, setMenuOpen] = useState(false);
  const [quizOpen, setQuizOpen] = useState(false);
  const [exitDrawer, setExitDrawer] = useState(false);
  const [selectedWine, setSelectedWine] = useState<Wine | null>(null);
  const handleLoaded = useCallback(() => setLoaded(true), []);

  // Safety fallback: force loaded after 2.5s in case Loader doesn't fire (e.g. headless)
  useEffect(() => {
    const t = setTimeout(() => setLoaded(true), 2500);
    return () => clearTimeout(t);
  }, []);

  // Exit intent
  useEffect(() => {
    const shown = { val: false };
    const onLeave = (e: MouseEvent) => {
      if (e.clientY <= 0 && !shown.val) {
        shown.val = true;
        setExitDrawer(true);
      }
    };
    document.addEventListener('mouseleave', onLeave);
    return () => document.removeEventListener('mouseleave', onLeave);
  }, []);

  useEffect(() => {
    if (!loaded) return;
    const ctx = gsap.context(() => {
      gsap.utils.toArray<HTMLElement>('.reveal-clip').forEach((el) => {
        gsap.fromTo(el,
          { clipPath: 'inset(0 0 100% 0)', opacity: 1 },
          { clipPath: 'inset(0 0 0% 0)', duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 82%' } }
        );
      });
      gsap.utils.toArray<HTMLElement>('.reveal-up').forEach((el) => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: Number(el.dataset.delay ?? 0), scrollTrigger: { trigger: el, start: 'top 85%' } }
        );
      });
      gsap.to('.hero-parallax', {
        yPercent: 18, ease: 'none',
        scrollTrigger: { trigger: '.hero-section', start: 'top top', end: 'bottom top', scrub: true },
      });

      const panels = gsap.utils.toArray<HTMLElement>('.ch-panel');
      panels.forEach((p, i) => gsap.set(p, { opacity: i === 0 ? 1 : 0, yPercent: i === 0 ? 0 : 12 }));

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: scrollStageRef.current,
          pin: true,
          start: 'top top',
          end: `+=${(panels.length - 1) * 100}vh`,
          scrub: 1.2,
          anticipatePin: 1,
        },
      });

      panels.forEach((panel, i) => {
        if (i === panels.length - 1) return;
        const next = panels[i + 1];
        tl.to(panel.querySelectorAll('.ch-t'), { opacity: 0, y: -28, duration: 0.3, stagger: 0.05, ease: 'power2.in' }, i)
          .to(panel.querySelector('.ch-img'), { opacity: 0, scale: 0.9, duration: 0.35, ease: 'power2.in' }, i)
          .to(panel, { opacity: 0, duration: 0.1 }, i + 0.38)
          .fromTo(next, { opacity: 0, yPercent: 12 }, { opacity: 1, yPercent: 0, duration: 0.1 }, i + 0.4)
          .fromTo(next.querySelector('.ch-img'), { opacity: 0, scale: 0.88, y: 35 }, { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: 'power3.out' }, i + 0.44)
          .fromTo(next.querySelectorAll('.ch-t'), { opacity: 0, y: 28 }, { opacity: 1, y: 0, duration: 0.4, stagger: 0.07, ease: 'power2.out' }, i + 0.48);
      });
    }, containerRef);
    return () => ctx.revert();
  }, [loaded]);

  return (
    <>
      {/* Inject Playfair Display + Raleway */}
      <style>{`@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Raleway:wght@300;400;500;600&display=swap');`}</style>
      <Loader onDone={handleLoaded} />
      <CustomCursor />
      <ScrollProgress />
      {quizOpen && <QuizModal onClose={() => setQuizOpen(false)} />}
      {selectedWine && <WineDetailPanel wine={selectedWine} onClose={() => setSelectedWine(null)} />}

      {/* Exit intent drawer */}
      {exitDrawer && (
        <div className="fixed bottom-0 left-0 right-0 z-[290] p-4 pointer-events-none">
          <div className="max-w-2xl mx-auto rounded-3xl px-8 py-5 flex flex-col md:flex-row items-center gap-5 pointer-events-auto"
            style={{ background: 'rgba(250,248,243,0.97)', border: '1px solid rgba(92,26,42,0.2)', backdropFilter: 'blur(20px)', boxShadow: '0 -20px 60px -10px rgba(92,26,42,0.15)' }}>
            <div className="flex-1 text-center md:text-left">
              <p className="text-xs tracking-[0.2em] uppercase mb-1" style={{ fontFamily: F.ui, color: C.light }}>Un instant</p>
              <p className="text-xl font-light italic mb-0.5" style={{ fontFamily: F.display, color: '#1a0a0a' }}>
                "Le vin est la chose la plus civilisée du monde."
              </p>
              <p className="text-xs" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.35)' }}>— Ernest Hemingway</p>
            </div>
            <div className="flex items-center gap-3 flex-shrink-0">
              <a href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" target="_blank" rel="noopener"
                className="px-6 py-2.5 rounded-full text-sm tracking-[0.1em] uppercase whitespace-nowrap"
                style={{ fontFamily: F.ui, background: `linear-gradient(135deg, ${C.dark}, ${C.primary})` }}>
                Voir nos cuvées
              </a>
              <button onClick={() => setExitDrawer(false)}
                className="p-2 rounded-full text-white/40 hover:text-white hover:bg-white/10 transition-all">
                <X className="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Floating quiz button */}
      <button onClick={() => setQuizOpen(true)}
        className="fixed bottom-6 right-6 z-[280] w-14 h-14 rounded-full flex items-center justify-center group"
        style={{ background: `linear-gradient(135deg, ${C.dark}, ${C.primary})`, boxShadow: `0 8px 30px -6px rgba(92,26,42,0.7)` }}>
        <span className="text-xl">🍷</span>
        <span className="absolute -top-10 right-0 bg-black/90 text-white text-xs px-3 py-1.5 rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
          style={{ fontFamily: F.ui }}>
          Trouvez votre cuvée
        </span>
      </button>

      <div ref={containerRef} className="min-h-screen overflow-x-hidden"
        style={{ fontFamily: F.ui, background: '#faf8f3', color: '#1a0a0a', opacity: loaded ? 1 : 0, transition: 'opacity 0.4s ease' }}>

        {/* ── Navigation ─────────────────────────────────────────────────── */}
        <nav className="fixed top-0 left-0 w-full z-50 px-6 md:px-10 py-5 flex justify-between items-center"
          style={{ background: 'linear-gradient(180deg, rgba(250,248,243,0.95) 0%, rgba(250,248,243,0) 100%)', backdropFilter: 'blur(2px)' }}>
          <div className="flex items-center gap-3">
            <img src="https://assets.evolusite.fr/3/m9j30seelogo-famille-cognard-vigneron_VouLI0vRN.png?tr=h-250"
              alt="Famille Cognard" className="h-10 object-contain"
              style={{ filter: 'brightness(0) invert(1)' }}
              onError={e => {
                const img = e.currentTarget;
                img.style.display = 'none';
                const fallback = img.nextElementSibling as HTMLElement;
                if (fallback) fallback.style.display = 'flex';
              }} />
            <span className="hidden items-center gap-1.5" style={{ fontFamily: F.display }}>
              <span className="text-white font-light text-lg tracking-wide">Famille</span>
              <span className="font-light text-lg tracking-wide" style={{ color: C.light }}>Cognard</span>
            </span>
          </div>
          <div className="hidden md:flex items-center gap-8">
            {[
              { label: 'Nos Cuvées', href: '#cuvees' },
              { label: 'Le Vignoble', href: '#vignoble' },
              { label: 'La Maison', href: '#histoire' },
              { label: 'Agenda', href: '#agenda' },
              { label: 'Contact', href: '#contact' },
            ].map(({ label, href }) => (
              <a key={label} href={href}
                className="relative text-xs tracking-[0.15em] uppercase transition-colors group"
                style={{ color: 'rgba(26,10,10,0.5)' }}
                onMouseEnter={e => (e.currentTarget.style.color = '#1a0a0a')}
                onMouseLeave={e => (e.currentTarget.style.color = 'rgba(26,10,10,0.5)')}
                style={{ fontFamily: F.ui }}>
                {label}
                <span className="absolute -bottom-0.5 left-0 h-px w-0 group-hover:w-full transition-all duration-300"
                  style={{ background: C.light }} />
              </a>
            ))}
            <MagneticButton href="https://vins-stnicolas-bourgueil-cognard.fr" target="_blank" rel="noopener"
              className="flex items-center gap-2 px-5 py-2 rounded-full text-xs tracking-[0.15em] uppercase transition-all"
              style={{ fontFamily: F.ui, border: `1px solid rgba(92,26,42,0.3)`, color: C.primary, background: 'rgba(92,26,42,0.05)' } as React.CSSProperties}>
              <ShoppingBag className="w-3.5 h-3.5" /> Commander
            </MagneticButton>
          </div>
          <button className="md:hidden p-2" onClick={() => setMenuOpen(true)}>
            <Menu className="w-5 h-5" />
          </button>
        </nav>

        {/* Mobile menu */}
        {menuOpen && (
          <div className="fixed inset-0 z-[200] flex flex-col items-center justify-center gap-8"
            style={{ background: 'rgba(250,248,243,0.97)', backdropFilter: 'blur(20px)' }}>
            <button className="absolute top-5 right-6" onClick={() => setMenuOpen(false)}>
              <X className="w-6 h-6" />
            </button>
            {['Nos Cuvées', 'Le Vignoble', 'La Maison', 'Actualités', 'Contact'].map((item, i) => (
              <a key={item} href="#" onClick={() => setMenuOpen(false)}
                className="text-4xl font-light transition-colors"
                style={{ color: 'rgba(26,10,10,0.6)' }}
                onMouseEnter={e => (e.currentTarget.style.color = '#1a0a0a')}
                onMouseLeave={e => (e.currentTarget.style.color = 'rgba(26,10,10,0.6)')}
                style={{ fontFamily: F.display, animationDelay: `${i * 0.07}s` }}>
                {item}
              </a>
            ))}
          </div>
        )}

        {/* ── HERO ───────────────────────────────────────────────────────── */}
        <WavyBackground
          containerClassName="hero-section"
          className="w-full text-center px-6"
          blur={20}
          speed="slow"
          waveOpacity={0.35}
          colors={['#d4b896', '#c4956e', '#b8963e', '#cba882', '#e8d5b0']}
          backgroundFill="#faf8f3"
        >
          <div className="absolute inset-0 z-0 pointer-events-none opacity-[0.12]"
            style={{
              backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")`,
              backgroundSize: '256px 256px',
            }} />

          <div className="hero-parallax relative z-10 flex flex-col items-center gap-5">
            <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-xs tracking-[0.25em] uppercase mb-2"
              style={{ fontFamily: F.ui, borderColor: 'rgba(92,26,42,0.4)', background: 'rgba(92,26,42,0.07)', color: C.primary }}>
              <span className="w-1.5 h-1.5 rounded-full animate-pulse" style={{ background: C.light }} />
              Fondée en 1973 · Val de Loire, France
            </div>

            <h1 className="text-[clamp(3.5rem,12vw,9rem)] font-light leading-[0.88]"
              style={{ fontFamily: F.display, letterSpacing: '-0.02em', color: '#1a0a0a' }}>
              FAMILLE
              <em className="block not-italic" style={{ color: C.primary }}>Cognard</em>
            </h1>

            <p className="text-xs md:text-sm tracking-[0.3em] uppercase mt-3" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.4)' }}>
              Cabernet Franc · Bourgueil · Saint-Nicolas · Agriculture Biologique
            </p>

            <p className="text-sm md:text-base max-w-md mx-auto leading-[1.7] mt-1" style={{ color: 'rgba(26,10,10,0.55)' }}
              style={{ fontFamily: F.display, fontStyle: 'italic' }}>
              {seasonalCopy}
            </p>

            <div className="mt-10 flex items-center gap-6">
              <PremiumButton 
                href="https://vins-stnicolas-bourgueil-cognard.fr/nos-cuvees" 
                target="_blank" 
                rel="noopener"
                variant="primary"
                size="lg"
                style={{ fontFamily: F.ui }}
              >
                Découvrir nos cuvées
                <ArrowRight className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
              </PremiumButton>
              <a href="#histoire" className="text-xs tracking-[0.2em] uppercase transition-colors"
                style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.4)' }}>
                Notre histoire
              </a>
            </div>

            <div className="mt-12 flex flex-col items-center gap-2 text-white/20">
              <div className="w-px h-12 bg-gradient-to-b from-white/20 to-transparent" />
            </div>
          </div>
        </WavyBackground>

        {/* ── MARQUEE 1 ─────────────────────────────────────────────────── */}
        <Marquee />

        {/* ── SCROLL-PINNED CHAPTERS ────────────────────────────────────── */}
        <div ref={scrollStageRef} className="relative h-screen overflow-hidden" style={{ background: '#f0ebe0' }}>
          <div className="absolute inset-0 pointer-events-none"
            style={{ background: `radial-gradient(ellipse 55% 50% at 50% 50%, rgba(92,26,42,0.16) 0%, transparent 70%)` }} />
          <TufeauTexture />

          {chapters.map((ch, idx) => (
            <div key={idx} className="ch-panel absolute inset-0 flex flex-col items-center justify-center">
              <div className="ch-t absolute top-24 right-8 md:right-16 flex items-center gap-3">
                <span className="text-xs tracking-widest" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.25)' }}>{ch.label} / 0{chapters.length}</span>
                <div className="w-10 h-px bg-white/10" />
              </div>

              <div className="flex items-center gap-8 md:gap-20 px-6 flex-wrap justify-center">
                <span className="ch-t text-[clamp(3rem,8vw,6rem)] font-light"
                  style={{ color: 'rgba(26,10,10,0.8)' }}
                  style={{ fontFamily: F.display, letterSpacing: '-0.02em' }}>
                  {ch.left}
                </span>

                <div className="ch-img relative flex-shrink-0">
                  <div className="absolute inset-0 rounded-2xl z-10 pointer-events-none mix-blend-multiply"
                    style={{ background: `linear-gradient(160deg, rgba(92,26,42,0.3), transparent 60%)` }} />
                  <div className="absolute inset-0 rounded-2xl z-10 pointer-events-none bg-gradient-to-t from-black/60 via-transparent to-transparent" />
                  <img src={ch.image} alt={ch.right}
                    className="w-56 md:w-80 h-40 md:h-56 object-cover rounded-2xl"
                    style={{ boxShadow: `0 30px 80px -10px rgba(92,26,42,0.55), 0 10px 30px -5px rgba(0,0,0,0.9)` }} />
                  <div className="absolute -bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-20">
                    {chapters.map((_, i) => (
                      <div key={i} className="h-0.5 rounded-full"
                        style={{ width: i === idx ? '24px' : '6px', background: i === idx ? C.primary : 'rgba(255,255,255,0.15)' }} />
                    ))}
                  </div>
                </div>

                <em className="ch-t not-italic text-[clamp(3rem,8vw,6rem)] font-light"
                  style={{ fontFamily: F.display, letterSpacing: '-0.02em', color: '#8b3a1a', fontStyle: 'italic' }}>
                  {ch.right}
                </em>
              </div>

              <p className="ch-t absolute bottom-20 left-1/2 -translate-x-1/2 text-center text-xs md:text-sm tracking-[0.22em] uppercase whitespace-nowrap"
                style={{ color: 'rgba(26,10,10,0.35)' }}
                style={{ fontFamily: F.ui }}>
                {ch.subtitle}
              </p>
            </div>
          ))}
        </div>

        {/* ── CHIFFRES CLÉS ─────────────────────────────────────────────── */}
        <section className="relative py-20 px-6 overflow-hidden" style={{ background: '#ede8df' }}>
          <TufeauTexture />
          <div className="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4">
            <StatCounter value={1973} label="année de fondation" />
            <StatCounter value={3} label="générations" />
            <StatCounter value={15} label="hectares de vignes" />
            <StatCounter value={8} label="cuvées au catalogue" />
          </div>
        </section>

        {/* ── NOTRE HISTOIRE ────────────────────────────────────────────── */}
        <section id="histoire" className="relative py-28 px-6 overflow-hidden" style={{ background: '#faf8f3' }}>
          <TufeauTexture />
          <div className="max-w-6xl mx-auto">
            <div className="text-center mb-20 space-y-4">
              <div className="reveal-up flex items-center justify-center gap-3">
                <Clock className="w-5 h-5" style={{ color: C.light }} />
                <span className="text-xs tracking-[0.25em] uppercase" style={{ fontFamily: F.ui, color: C.light }}>Notre Héritage</span>
              </div>
                <VariableText
                as="h2"
                className="reveal-up text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.05]"
                style={{ fontFamily: F.display }}
                weightStart={300}
                weightEnd={500}
                spacingStart={0.02}
                spacingEnd={-0.02}
                scaleStart={1}
                scaleEnd={1.02}
                breathe={true}
                breatheDuration={4}
              >
                Trois générations<br /><em style={{ color: '#8b3a1a' }}>au service du Cabernet</em>
              </VariableText>
              <p className="reveal-up max-w-2xl mx-auto text-lg leading-[1.8]" data-delay="0.15" style={{ color: 'rgba(26,10,10,0.5)' }}>
                En 1973, Lydie et Max Cognard plantent leur premier hectare de Cabernet Franc à Saint-Nicolas-de-Bourgueil.
                Ce cépage unique, ces terres de tuffeau, deviendront l'héritage d'une saga familiale de plus de 50 ans.
              </p>
            </div>

            <div className="reveal-clip mb-20 rounded-2xl overflow-hidden max-w-4xl mx-auto">
              <img src="https://assets.evolusite.fr/ik-seo/3/xwgsun72vacozjglyp9yw_gqH-6nzR1/estelle-et-rodolphe-maison-cognard.JPG"
                alt="Famille Cognard — Estelle et Rodolphe"
                className="w-full h-72 md:h-96 object-cover" />
            </div>

            <div className="reveal-up overflow-x-auto pb-4" style={{ scrollbarWidth: 'none' }}>
              <div className="flex gap-0 min-w-max">
                {timeline.map((item, i) => (
                  <div key={i} className="relative flex flex-col items-start" style={{ width: '220px', flexShrink: 0 }}>
                    <div className="flex items-center w-full mb-6">
                      <div className="w-4 h-4 rounded-full border-2 flex-shrink-0 z-10"
                        style={{ borderColor: C.primary, background: i === 0 ? C.primary : 'transparent' }} />
                      {i < timeline.length - 1 && (
                        <div className="h-px flex-1" style={{ background: `linear-gradient(90deg, ${C.primary}, rgba(92,26,42,0.2))` }} />
                      )}
                    </div>
                    <div className="pr-6">
                      <p className="text-2xl font-light mb-1" style={{ fontFamily: F.display, color: C.light }}>{item.year}</p>
                      <p className="text-sm font-medium mb-2" style={{ fontFamily: F.ui, color: 'rgba(26,10,10,0.8)' }}>{item.title}</p>
                      <p className="text-xs leading-[1.7]" style={{ color: 'rgba(26,10,10,0.45)' }}>{item.text}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        {/* ── NOS CUVÉES ────────────────────────────────────────────────── */}
