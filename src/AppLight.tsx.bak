                    <p className="text-sm font-medium" style={{ color: C.light, fontFamily: F.ui }}>☎ {domaine.phone}</p>
                    <p className="text-sm text-white/35" style={{ fontFamily: F.ui }}>{domaine.email}</p>
                  </div>
                </div>
              </TiltCard>

              <div className="rounded-2xl p-6" style={{ background: '#fff', border: '1px solid rgba(92,26,42,0.1)', boxShadow: '0 4px 20px rgba(92,26,42,0.06)' }}>
                <div className="flex items-center gap-3 mb-6">
                  <Star className="w-5 h-5" style={{ color: C.light }} />
                  <p className="text-xs tracking-[0.25em] uppercase" style={{ fontFamily: F.ui, color: C.light }}>Agenda 2026</p>
                </div>
