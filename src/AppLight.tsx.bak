                  <p className="text-xs mb-1.5" style={{ color: C.light, fontFamily: F.ui }}>{t.sub}</p>
                  <p className="text-xs leading-snug" style={{ color: 'rgba(26,10,10,0.35)' }}>{t.desc}</p>
                </TiltCard>
              ))}
            </div>
          </div>
